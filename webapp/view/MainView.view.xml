<mvc:View controllerName="project2.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:m="sap.m">
    <NavContainer id="navCont">
        <Page id="page1" title="{i18n>title}" class="Pages">
        
            <headerContent>
                <ComboBox id="LanguageComboBox" selectedKey="English"  change=".onLanguageChange" class="LanguageSelectBox">
                    <items>
                        <core:Item id="EnglishItem" key="English" text="English"/>
                        <core:Item id="FrenchItem" key="French" text="French"/>
                    </items>
                </ComboBox>
            </headerContent>

            <content>

                <!-- Search bar -->
                <HBox id="_IDGenHBox" class="sapUiSmallMargin">
                    <Input id="searchInput" width="200px" placeholder="{i18n>searchPlaceholder}" liveChange=".onSearch" class="InputFields"/>
                    <MultiComboBox id="filterCombo" selectionChange=".onSearch" placeholder="{i18n>filterPlaceholder}">
                        <items>
                            <!-- Customer fields -->
                            <core:Item id="_IDGenItem1" key="Customer/CompanyName" text="{i18n>Customer_CompanyName}"/>
                            <core:Item id="_IDGenItem2" key="Customer/ContactName" text="{i18n>Customer_ContactName}"/>
                            <core:Item id="_IDGenItem3" key="Customer/ContactTitle" text="{i18n>Customer_ContactTitle}"/>

                            <!-- Order fields -->
                            <core:Item id="_IDGenItem4" key="OrderID" text="{i18n>Order_OrderID}"/>
                            <core:Item id="_IDGenItem5" key="OrderDate" text="{i18n>Order_OrderDate}"/>
                            <core:Item id="_IDGenItem6" key="RequiredDate" text="{i18n>Order_RequiredDate}"/>
                            <core:Item id="_IDGenItem7" key="ShippedDate" text="{i18n>Order_ShippedDate}"/>
                            <core:Item id="_IDGenItem8" key="ShipName" text="{i18n>Order_ShipName}"/>

                            <!-- Product fields -->
                            <core:Item id="_IDGenItem9" key="Order_Details/Product/ProductName" text="{i18n>Product_ProductName}"/>
                            <core:Item id="_IDGenItem10" key="Order_Details/Product/ProductID" text="{i18n>Product_ProductID}"/>
                        </items>
                    </MultiComboBox>
                    <Button id="refreshButton" icon="sap-icon://refresh" press=".onRefresh"/>
                </HBox>

                <VBox id="_IDGenVBox" class="sapUiSmallMargin">
                    <!-- Orders Table -->
                    <Table id="ordersTable" items="{
                        path: '/Orders',
                        parameters: {
                            expand: 'Customer,Order_Details,Employee,Order_Details/Product'
                                    }
                    }" class="sapUiSmallMarginTop">

                        <!-- Table Header -->
                        <headerToolbar>
                            <Toolbar id="_IDGenToolbar">
                                <Title id="_IDGenTitle" text="{i18n>orders}"/>
                            </Toolbar>
                        </headerToolbar>

                        <!-- Columns -->
                        <columns>
                            <Column id="_IDGenColumn">
                                <Text id="_IDGenText2" text="{i18n>orderId}"/>
                            </Column>
                            <Column id="_IDGenColumn1">
                                <Text id="_IDGenText3" text="{i18n>orderDate}"/>
                            </Column>
                            <Column id="_IDGenColumn2">
                                <Text id="_IDGenText4" text="{i18n>requiredDate}"/>
                            </Column>
                            <Column id="_IDGenColumn4">
                                <Text id="_IDGenText6" text="{i18n>status}"/>
                            </Column>
                        </columns>

                        <!-- Table Items -->
                        <items>
                            <ColumnListItem id="_IDGenColumnListItem" type="Active" press=".onNavToSecond">
                                <cells>
                                    <Text id="_IDGenText" class="TableText"
                                        text="{ 
                                            parts: [ {path: 'OrderID'}, {path: 'Customer/ContactName'} ], 
                                            formatter: '.formatter.formatOrderContact' }"/>
                                    <Text id="_IDGenText5"  class="TableText"
                                        text="{ path: 'OrderDate', formatter: '.formatter.formatDateShort' }"/>
                                    <Text id="_IDGenText7"  class="TableText"
                                        text="{ path: 'RequiredDate', formatter: '.formatter.formatDateShort' }"/>
                                    <ObjectStatus id="_IDGenObjectStatus" 
                                    text="{ 
                                        parts: [ {path: 'RequiredDate'}, {path: 'ShippedDate'} ], 
                                        formatter: '.formatter.GetOrderStatus' }"
                                    state="{ 
                                        parts: [ {path: 'RequiredDate'}, {path: 'ShippedDate'} ], 
                                        formatter: '.formatter.GetOrderStatusState' }"/>
                                </cells>
                            </ColumnListItem>
                        </items>

                    </Table>
                </VBox>

            </content>
        </Page>
        <Page id="page2" title="{i18n>orderDetailsTitle}" class="Pages">
        <!-- Back button in the page header --> 
            <headerContent> 
                <Button id="_IDGenButton2" text="{i18n>back}" press=".onNavBack" type="Transparent"/> 
            </headerContent>

            <content>
                <VBox id="_IDGenVBox1" class="sapUiSmallMargin">

                    <HBox id="_IDGenHBox1">
                        <!-- Order Summary -->
                        <Panel id="OrderSummaryPanel" headerText="{i18n>orderSummary}" class="sapUiSmallMarginEnd myShippingPanel">
                            <VBox id="_IDGenVBox2" class="sapUiSmallMarginEnd">
                                <Text id="_IDGenText8" text="{i18n>orderId}: {OrderID}"/>
                                <Text id="_IDGenText9" text="{i18n>employeeName}: {Employee/FirstName} {Employee/LastName}"/>
                                <Text id="_IDGenText10" text="{i18n>orderDate}: { path: 'OrderDate', formatter: '.formatter.formatDateShort' }"/>
                                <Text id="_IDGenText11" text="{i18n>requiredDate}: { path: 'RequiredDate', formatter: '.formatter.formatDateShort' }"/>
                                <Text id="_IDGenText12" text="{i18n>shippedDate}: { path: 'ShippedDate', formatter: '.formatter.formatDateShort' }"/>
                                <Text id="_IDGenText13" text="{i18n>shipName}: {ShipName}"/>
                                <ObjectStatus id="_IDGenObjectStatus2" 
                                        text="{ 
                                            parts: [ {path: 'RequiredDate'}, {path: 'ShippedDate'} ], 
                                            formatter: '.formatter.GetOrderStatus' }"
                                        state="{ 
                                            parts: [ {path: 'RequiredDate'}, {path: 'ShippedDate'} ], 
                                            formatter: '.formatter.GetOrderStatusState' }"/>
                            </VBox>
                        </Panel>

                        <!-- Shipping Address -->
                        <Panel id="ShippingAddressOrder" headerText="{i18n>shippingAddress}" class="sapUiSmallMarginBegin Panels">
                            <VBox id="_IDGenVBox3" class="sapUiSmallMarginBegin">
                                <Text id="_IDGenText14" text="{ShipAddress}"/>
                                <Text id="_IDGenText15" text="{ShipCity}, {ShipPostalCode}"/>
                                <Text id="_IDGenText16" text="{ShipCountry}"/>
                            </VBox>
                        </Panel>
                    </HBox>

                    <!-- Item List -->
                    <Panel id="ItemListPanel" headerText="{i18n>itemList}" class="sapUiSmallMarginTop Panels">
                        <Table id="orderDetailsTable" items="{Order_Details}" updateFinished=".onOrderDetailsFinished">
                            <columns>
                                <Column id="_IDGenColumn5"><Text id="_IDGenText17" text="{i18n>productName}"/></Column>
                                <Column id="_IDGenColumn6"><Text id="_IDGenText18" text="{i18n>unitPrice}"/></Column>
                                <Column id="_IDGenColumn7"><Text id="_IDGenText19" text="{i18n>quantity}"/></Column>
                                <Column id="_IDGenColumn8"><Text id="_IDGenText20" text="{i18n>discount}"/></Column>
                                <Column id="_IDGenColumn9"><Text id="_IDGenText21" text="{i18n>subtotal}"/></Column>
                            </columns>
                            <items>
                                <ColumnListItem id="_IDGenColumnListItem1">
                                    <cells>
                                        <Text id="_IDGenText22" text="{Product/ProductName}"/>
                                        <Text id="_IDGenText23" text="{ 
                                            parts: [ {path: 'UnitPrice'}], 
                                            formatter: '.formatter.RandFormatter' }"/>
                                        <Text id="_IDGenText24" text="{Quantity}"/>
                                        <Text id="_IDGenText25" text="{ 
                                            parts: [ {path: 'Discount'}], 
                                            formatter: '.formatter.DiscountFormatter' }"/>
                                        <Text id="_IDGenText26" text="{ 
                                            parts: [ {path: 'UnitPrice'}, {path: 'Quantity'}, {path: 'Discount'}], 
                                            formatter: '.formatter.SubTotalFormatter' }"/>
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>

                        <!-- Totals -->
                        <VBox id="OrderTotalsText">
                            <Text id="orderSubTotalTitle" text="Order Subtotal: " class="sapUiSmallMarginTop"/>
                            <Text id="orderDiscountTitle" text="Total Discount: " />
                            <Title id="orderTotalTitle" level="H2"/>
                        </VBox>
                    </Panel>
                    
                    <!-- Customer Information -->
                    <HBox id="_IDGenHBox2">
                        <!-- Customer Details -->
                        <Panel id="CustomerDetailsPanel" class="sapUiSmallMarginTop sapUiSmallMarginEnd Panels" headerText="{i18n>customerInformation}">
                            <VBox id="_IDGenVBox4" class="sapUiSmallMarginEnd">
                                <Text id="_IDGenText27" text="Company Name: {Customer/CompanyName}"/>
                                <Text id="_IDGenText28" text="Contact Name: {Customer/ContactName}"/>
                                <Text id="_IDGenText29" text="Job Title: {Customer/ContactTitle}"/>
                            </VBox>
                        </Panel>

                        <!-- Customer Address -->
                        <Panel id="AddressCustomerPanel" class="sapUiSmallMarginTop sapUiSmallMarginBegin Panels" headerText="{i18n>address}">
                            <VBox id="_IDGenVBox5" class="sapUiSmallMarginBegin">
                                <Text id="_IDGenText30" text="{Customer/Address}"/>
                                <Text id="_IDGenText31" text="{Customer/City}, {Customer/PostalCode}"/>
                                <Text id="_IDGenText32" text="{Customer/Country}"/>
                            </VBox>
                        </Panel>
                    </HBox>
                    
                    <!-- Customer Contact -->
                    <Panel id="CustomerContactInformationPanel" class="sapUiSmallMarginTop Panels" headerText="{i18n>contactInformation}">
                        <VBox id="CustomerContactInformationVBox">
                            <Text id="_IDGenText33" text="Phone: {Customer/Phone}"/>
                            <Text id="_IDGenText34" text="Fax: {Customer/Fax}"/>
                        </VBox>
                    </Panel>
                </VBox>
            </content>
        </Page>
    </NavContainer>
</mvc:View>